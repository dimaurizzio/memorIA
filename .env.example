# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Base de datos (PostgreSQL local — en Docker se sobreescribe automáticamente)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memoria

# GenAI Toolbox
TOOLBOX_URL=http://localhost:5000

# Tableau MCP
TABLEAU_SERVER_URL=your_tableau_server_url
TABLEAU_SITE=your_tableau_site_id  # Solo Tableau Cloud — omitir en Server on-premise
TABLEAU_TOKEN_NAME=your_token_name
TABLEAU_TOKEN_VALUE=your_token_value

# App
APP_SECRET_KEY=random_secret_key
ENVIRONMENT=development

# Trackeo de la cadena de razonamiento del agente con LangSmith (opcional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT=""
